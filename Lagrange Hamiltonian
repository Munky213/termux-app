        "            file_handler.setFormatter(formatter)\n",
        "            self.logger.addHandler(file_handler)\n",
        "            self.logger.propagate = False # Prevent messages from going to root logger\n",
        "\n",
        "    def _calculate_lagrange_cost(self, current_sig: str, action, next_sig: str) -> int:\n",
        "        # Lagrange cost represents the immediate cost of taking an action.\n",
        "        # For simplicity, let's assign a base cost to each action.\n",
        "        # This could be extended based on action type, agent state, or environment features.\n",
        "        base_cost = 1 # A constant positive integer for movement cost\n",
        "\n",
        "        # Example: if action involves 'ACTION4' it might be more costly\n",
        "        if hasattr(action, 'name') and 'ACTION4' in action.name: # Check for GameAction enum\n",
        "            return base_cost + 2\n",
        "        elif isinstance(action, str) and 'ACTION4' in action: # Check for string actions\n",
        "            return base_cost + 2\n",
        "\n",
        "        return base_cost\n",
        "\n",
        "    def _calculate_hamiltonian_cost(self, next_sig: str) -> int:\n",
        "        # Interpreting \"Hamiltonian representation\" as a state-dependent cost (potential energy).\n",
        "        # This cost is added to the base cost of taking an action.\n",
        "        # \"Reciprositive\" can be interpreted as a property of this potential,\n",
        "        # where the cost of reaching a state is independent of the path taken to get there,\n",
        "        # implying the potential is a state function.\n",
        "\n",
        "        potential_energy = 0.0\n",
        "        try:\n",
        "            # If the signature is a hexadecimal string (like those generated by _enc)\n",
        "            # sum the integer values of its hex digits as a proxy for state \"complexity\" or \"magnitude\".\n",
        "            for char_digit in next_sig:\n",
        "                potential_energy += int(char_digit, 16)\n",
        "        except ValueError:\n",
        "            # If the signature is not a hex string (e.g., \"StateA\", \"StateB\"),\n",
        "            # use a simple heuristic based on its length or a default value.\n",
        "            # This handles the manually created test states.\n",
        "            potential_energy = len(next_sig) * 1.0 # Simple length-based potential\n",
        "\n",
        "        # Ensure the cost is a positive integer. Max of 1 to ensure minimum positive cost.\n",
        "        return max(1, int(round(potential_energy / 10.0))) # Normalize and convert to integer\n",
        "\n",
        "    def get_shortest_path(self, start_sig, goal_sig):\n",
        "        # Check cache first\n",
        "        cache_key = (start_sig, goal_sig)\n",
        "        if cache_key in self._path_cache:\n",
        "            self.logger.info(f\"Path from {start_sig} to {goal_sig} found in cache.\")\n",
