        "            return []\n",
        "\n",
        "        pq = [(0, start_sig, [])]  # (cost, current_signature, path_to_here)\n",
        "        visited = {start_sig: 0}\n",
        "        found_path = None\n",
        "\n",
        "        while pq:\n",
        "            dist, curr, path = heapq.heappop(pq)\n",
        "            self.logger.debug(f\"Exploring node {curr} with distance {dist}. Current path: {path}\")\n",
        "\n",
        "            if curr == goal_sig:\n",
        "                self.logger.info(f\"Path found from {start_sig} to {goal_sig}: {path}\")\n",
        "                found_path = path\n",
        "                break # Exit loop once goal is reached\n",
        "\n",
        "            # If we found a shorter path to 'curr' already, skip\n",
        "            if dist > visited.get(curr, float('inf')):\n",
        "                self.logger.debug(f\"Skipping {curr} as a shorter path already exists.\")\n",
        "                continue\n",
        "\n",
        "            # Explore neighbors\n",
        "            for act, next_sig in self._GRPH.get(curr, {}).items():\n",
