        "print(\"\\n--- Analysis of Long Simulation Log ---\")\n",
        "long_sim_results = analyze_log_file(long_sim_log)\n",
        "if long_sim_results:\n",
        "    print(f\"Total get_shortest_path calls (attempts): {long_sim_results['path_attempts']}\")\n",
        "    print(f\"Actual path computations (no cache in this log): {long_sim_results['path_computations']}\")\n",
        "    print(f\"Paths successfully found: {long_sim_results['paths_found']}\")\n",
        "    print(f\"No paths found: {long_sim_results['no_paths_found']}\")\n",
