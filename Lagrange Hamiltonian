        "\n",
        "                # Calculate Lagrange cost (movement cost) for the action\n",
        "                lagrange_cost = self._calculate_lagrange_cost(curr, act, next_sig)\n",
        "                # Calculate Hamiltonian cost (state potential) for the next state\n",
        "                hamiltonian_cost = self._calculate_hamiltonian_cost(next_sig)\n",
        "\n",
        "                # Total action cost is the sum, ensuring it's a positive integer\n",
        "                total_action_cost = lagrange_cost + hamiltonian_cost\n",
        "\n",
        "                new_dist = dist + total_action_cost\n",
        "\n",
        "                if new_dist < visited.get(next_sig, float('inf')):\n",
        "                    visited[next_sig] = new_dist\n",
        "                    heapq.heappush(pq, (new_dist, next_sig, path + [act]))\n",
        "                    self.logger.debug(f\"Found shorter path to {next_sig} (new_dist={new_dist}, Lagrange={lagrange_cost}, Hamiltonian={hamiltonian_cost}). Adding to queue.\")\n",
        "\n",
        "        if found_path is not None:\n",
        "            self._path_cache[cache_key] = found_path # Cache the found path\n",
        "            return found_path\n",
        "        else:\n",
        "            self.logger.warning(f\"No path found from {start_sig} to {goal_sig}\")\n",
