        "import re\n",
        "\n",
        "def analyze_log_file(log_file_path):\n",
        "    path_attempts = 0\n",
        "    path_computations = 0\n",
        "    cache_hits = 0\n",
        "    paths_found = 0\n",
        "    no_paths_found = 0\n",
        "\n",
        "    try:\n",
        "        with open(log_file_path, 'r') as f:\n",
        "            for line in f:\n",
        "                if \"Starting get_shortest_path\" in line: # Indicates a pathfinding attempt (either new or cache miss)\n",
        "                    path_attempts += 1\n",
        "                    path_computations += 1 # Assume computation starts\n",
        "                elif \"Path from\" in line and \"found in cache\" in line: # Indicates a cache hit\n",
        "                    cache_hits += 1\n",
        "                    path_computations -= 1 # It was a cache hit, so no computation actually happened\n",
        "                elif \"Path found from\" in line: # A path was successfully found\n",
        "                    paths_found += 1\n",
        "                elif \"No path found from\" in line: # No path was found\n",
        "                    no_paths_found += 1\n",
        "    except FileNotFoundError:\n",
        "        print(f\"Error: Log file not found at {log_file_path}\")\n",
        "        return None\n",
        "    except Exception as e:\n",
        "        print(f\"An error occurred while reading {log_file_path}: {e}\")\n",
        "        return None\n",
        "\n",
        "    return {\n",
        "        'path_attempts': path_attempts,\n",
        "        'path_computations': path_computations, # Actual computations, excluding cache hits\n",
        "        'cache_hits': cache_hits,\n",
        "        'paths_found': paths_found,\n",
        "        'no_paths_found': no_paths_found\n",
        "    }\n",
