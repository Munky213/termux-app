        "import numpy as np\n",
        "import math\n",
        "import hashlib\n",
        "from collections import deque\n",
        "import heapq\n",
        "import logging\n",
        "\n",
        "_FIB = [1, 2, 3, 5, 8, 13, 21, 34, 55]\n",
        "\n",
        "def _enc(g: np.ndarray, n: int = 9) -> str:\n",
        "    if g.size == 0: return '0'\n",
        "    g_fixed = np.where(g == 0, 1, g)\n",
        "    t = g_fixed.ravel().astype(float) * (2 * math.pi / 16)\n",
        "    sig = []\n",
        "    for k in _FIB[:n]:\n",
        "        c = np.mean(np.exp(1j * k * t))\n",
        "        sig += [int(round(c.real * 1000)), int(round(c.imag * 1000))]\n",
        "    return hashlib.sha256(np.array(sig, dtype=np.int64).tobytes()).hexdigest()[:16]\n",
        "\n",
        "class MyAgent:\n",
        "    def __init__(self, instance_id: str):\n",
        "        self.instance_id = instance_id\n",
        "        self.action_counter = 0\n",
        "        self._GRPH = {}\n",
        "        self._last_sig = None\n",
        "        self._last_act = None\n",
        "        self._target_sig = None\n",
        "        self._history = deque(maxlen=5)\n",
        "        self._loss_motifs = ['ACTION1 -> ACTION2 -> ACTION3']\n",
        "        self._path_cache = {} # Initialize path cache\n",
        "\n",
        "        # Configure logger for this agent instance\n",
        "        self.logger = logging.getLogger(f'MyAgent.{self.instance_id}')\n",
        "        self.logger.setLevel(logging.INFO) # Set to logging.DEBUG to see granular search progress\n",
